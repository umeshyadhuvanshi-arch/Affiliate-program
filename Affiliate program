function QRCode({ value, size = 176 }) {
  const cells = 21, cellSize = size / cells;
  const hash = Array.from(value).reduce((a, c) => a + c.charCodeAt(0), 0);
  const grid = Array.from({ length: cells }, (_, r) =>
    Array.from({ length: cells }, (_, c) => {
      if ((r < 7 && c < 7) || (r < 7 && c >= cells - 7) || (r >= cells - 7 && c < 7)) return 1;
      if (r === 6 || c === 6) return (r + c) % 2 === 0 ? 1 : 0;
      return ((hash * (r + 1) * (c + 1) + r * 31 + c * 17) % 3 === 0) ? 1 : 0;
    })
  );
  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
      <rect width={size} height={size} fill="white" />
      {grid.map((row, r) => row.map((cell, c) => cell ? <rect key={`${r}-${c}`} x={c*cellSize} y={r*cellSize} width={cellSize} height={cellSize} fill="#0A0F1E" /> : null))}
    </svg>
  );
}

