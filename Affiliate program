function OTPScreen({ phone, onVerified, isNew, goBack }) {
  const [otp, setOtp] = useState(["","","",""]);
  const [err, setErr] = useState("");
  const [loading, setLoading] = useState(false);
  const [cd, setCd] = useState(30);
  const refs = [useRef(),useRef(),useRef(),useRef()];
  useEffect(() => { const t = setInterval(()=>setCd(c=>c>0?c-1:0),1000); return ()=>clearInterval(t); }, []);
  function change(i, val) {
    if (!/^\d?$/.test(val)) return;
    const n=[...otp]; n[i]=val; setOtp(n);
    if (val && i<3) refs[i+1].current.focus();
  }
  function keydown(i,e) { if(e.key==="Backspace"&&!otp[i]&&i>0) refs[i-1].current.focus(); }
  async function verify() {
    const code=otp.join("");
    if (code.length<4){setErr("Enter the 4-digit OTP");return;}
    if (code!=="1234"){setErr("Incorrect OTP. (Demo: use 1234)");return;}
    setLoading(true);
    try { await onVerified(); } catch(e) { setErr(e.message); setLoading(false); }
  }
  return (
    <div className="card">
      <button className="back-btn" onClick={goBack}>← Back</button>
      <div className="headline">Verify</div>
      <div className="title" style={{fontSize:24}}>Enter OTP</div>
      <div className="subtitle">Sent to {phone}</div>
      <div className="otp-row">
        {otp.map((v,i)=><input key={i} ref={refs[i]} className="otp-box" maxLength={1} value={v} onChange={e=>change(i,e.target.value)} onKeyDown={e=>keydown(i,e)} type="tel"/>)}
      </div>
      {err && <div className="err">{err}</div>}
      <button className="btn-primary" onClick={verify} disabled={loading}>{loading?"Verifying...":`Verify & ${isNew?"Register":"Login"}`}</button>
      <div className="note">
        {cd>0?`Resend in ${cd}s`:<span style={{color:"#6C63FF",cursor:"pointer"}} onClick={()=>setCd(30)}>Resend OTP</span>}
        <br/><span style={{color:"#F5C842"}}>Demo: use OTP 1234</span>
      </div>
    </div>
  );
}

